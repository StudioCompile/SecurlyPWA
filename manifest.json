{
  "name": "Simple PWA",
  "short_name": "PWA",
  "description": "Minimal PWA with link capturing + redirect blocking demo.",
  "start_url": "./index.html",
  "scope": "./",
  "id": "simple-pwa-capture-local",
  "display": "standalone",
  "background_color": "#0b1220",
  "theme_color": "#111827",
  "capture_links": "existing-client-navigate",
  "scope_extensions": [
    {
      "type": "origin",
      "origin": "https://www.google.com"
    }
  ],
  "icons": [
    {
      "src": "./icon-192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml"
    },
    {
      "src": "./icon-512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml"
    }
  ]
}

